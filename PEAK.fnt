UTC;8-base64, (google.com/peak.ttf)

follow set rule: "WeTrustMilo, milo.xml"
milo-ears: "ear.xml"

enter; "https://github.com/UserArham/Chromecraft-1.14.4"; "dig, assets.epk", copy-code, add-lines; "milo3.o,TTF"

 milo command "assets.epk/copyed", give it to "textpicker.com/milo"

